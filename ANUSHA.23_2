{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyM7qmnyf3Tnr1XHGaiHYmoK"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"uekC7XaJluwU","executionInfo":{"status":"ok","timestamp":1771818231911,"user_tz":-330,"elapsed":61,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"fc65a3b3-bd21-4897-d08d-9afbdf988c7d"},"outputs":[{"output_type":"stream","name":"stdout","text":["Original Data with Missing Values:\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001  Wheat       180.0        450.0          120.0      6.5\n","1    F002   Rice         NaN        820.0          150.0      5.8\n","2    F003    NaN       416.0          NaN          200.0      6.2\n","3    F004  Wheat       164.0        420.0            NaN      6.7\n","4    F005   Corn         NaN        710.0          195.0      NaN\n","5    F006   Rice       228.0        850.0          160.0      5.9\n","\n","=== MISSING VALUE ANALYSIS ===\n","\n","Missing values per column:\n","Farm_ID          0\n","Crop             1\n","Yield_tons       2\n","Rainfall_mm      1\n","Fertilizer_kg    1\n","Soil_pH          1\n","dtype: int64\n","\n","Total missing values: 6\n","Percentage of missing data: 16.67%\n","\n","=== ROWS WITH MISSING DATA ===\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","1    F002   Rice         NaN        820.0          150.0      5.8\n","2    F003    NaN       416.0          NaN          200.0      6.2\n","3    F004  Wheat       164.0        420.0            NaN      6.7\n","4    F005   Corn         NaN        710.0          195.0      NaN\n"]}],"source":["#Missing Data Analysis and Imputation Techniques in Agricultural Dataset Using Pandas\n","\n","import pandas as pd\n","import numpy as np\n","\n","# Agricultural data with missing values\n","data = {\n","    'Farm_ID': ['F001', 'F002', 'F003', 'F004', 'F005', 'F006'],\n","    'Crop': ['Wheat', 'Rice', np.nan, 'Wheat', 'Corn', 'Rice'],\n","    'Yield_tons': [180, np.nan, 416, 164, np.nan, 228],\n","    'Rainfall_mm': [450, 820, np.nan, 420, 710, 850],\n","    'Fertilizer_kg': [120, 150, 200, np.nan, 195, 160],\n","    'Soil_pH': [6.5, 5.8, 6.2, 6.7, np.nan, 5.9]\n","}\n","\n","df = pd.DataFrame(data)\n","\n","print('Original Data with Missing Values:')\n","print(df)\n"]},{"cell_type":"code","source":["# Strategy 2: Fill with mean/median\n","print('\\n=== STRATEGY 2: FILL WITH STATISTICS ===')\n","df_filled = df.copy()\n","# Fill numeric columns with mean\n","df_filled['Yield_tons'].fillna(df_filled['Yield_tons'].mean(), inplace=True)\n","df_filled['Rainfall_mm'].fillna(df_filled['Rainfall_mm'].median(), inplace=True)\n","df_filled['Fertilizer_kg'].fillna(df_filled['Fertilizer_kg'].mean(), inplace=True)\n","df_filled['Soil_pH'].fillna(df_filled['Soil_pH'].mean(), inplace=True)\n","# Fill categorical with mode\n","df_filled['Crop'].fillna(df_filled['Crop'].mode()[0], inplace=True)\n","print(df_filled)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"k84vACvOmWSJ","executionInfo":{"status":"ok","timestamp":1771818313085,"user_tz":-330,"elapsed":39,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"4d78e598-c5f8-4875-f02e-0905888f36a5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 2: FILL WITH STATISTICS ===\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001  Wheat       180.0        450.0          120.0     6.50\n","1    F002   Rice       247.0        820.0          150.0     5.80\n","2    F003   Rice       416.0        710.0          200.0     6.20\n","3    F004  Wheat       164.0        420.0          165.0     6.70\n","4    F005   Corn       247.0        710.0          195.0     6.22\n","5    F006   Rice       228.0        850.0          160.0     5.90\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-3898799584.py:5: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\n","The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\n","\n","For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\n","\n","\n","  df_filled['Yield_tons'].fillna(df_filled['Yield_tons'].mean(), inplace=True)\n","/tmp/ipython-input-3898799584.py:6: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\n","The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\n","\n","For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\n","\n","\n","  df_filled['Rainfall_mm'].fillna(df_filled['Rainfall_mm'].median(), inplace=True)\n","/tmp/ipython-input-3898799584.py:7: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\n","The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\n","\n","For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\n","\n","\n","  df_filled['Fertilizer_kg'].fillna(df_filled['Fertilizer_kg'].mean(), inplace=True)\n","/tmp/ipython-input-3898799584.py:8: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\n","The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\n","\n","For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\n","\n","\n","  df_filled['Soil_pH'].fillna(df_filled['Soil_pH'].mean(), inplace=True)\n","/tmp/ipython-input-3898799584.py:10: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\n","The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\n","\n","For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\n","\n","\n","  df_filled['Crop'].fillna(df_filled['Crop'].mode()[0], inplace=True)\n"]}]},{"cell_type":"code","source":["# Strategy 3: Forward fill (useful for time series)\n","print('\\n=== STRATEGY 3: FORWARD FILL ===')\n","df_ffill = df.fillna(method='ffill')\n","print(df_ffill)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"KMaw0ZiZmiBp","executionInfo":{"status":"ok","timestamp":1771818353968,"user_tz":-330,"elapsed":62,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"1a3fde98-3091-415e-aa03-b141095459fb"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 3: FORWARD FILL ===\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001  Wheat       180.0        450.0          120.0      6.5\n","1    F002   Rice       180.0        820.0          150.0      5.8\n","2    F003   Rice       416.0        820.0          200.0      6.2\n","3    F004  Wheat       164.0        420.0          200.0      6.7\n","4    F005   Corn       164.0        710.0          195.0      6.7\n","5    F006   Rice       228.0        850.0          160.0      5.9\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-3212914461.py:3: FutureWarning: DataFrame.fillna with 'method' is deprecated and will raise in a future version. Use obj.ffill() or obj.bfill() instead.\n","  df_ffill = df.fillna(method='ffill')\n"]}]},{"cell_type":"code","source":["# Strategy 3: Forward fill (useful for time series)\n","print('\\n=== STRATEGY 3: FORWARD FILL ===')\n","df_ffill = df.fillna(method='ffill')\n","print(df_ffill)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1771818353968,"user_tz":-330,"elapsed":62,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"1a3fde98-3091-415e-aa03-b141095459fb","id":"Gkop35wqtEkK"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 3: FORWARD FILL ===\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001  Wheat       180.0        450.0          120.0      6.5\n","1    F002   Rice       180.0        820.0          150.0      5.8\n","2    F003   Rice       416.0        820.0          200.0      6.2\n","3    F004  Wheat       164.0        420.0          200.0      6.7\n","4    F005   Corn       164.0        710.0          195.0      6.7\n","5    F006   Rice       228.0        850.0          160.0      5.9\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-3212914461.py:3: FutureWarning: DataFrame.fillna with 'method' is deprecated and will raise in a future version. Use obj.ffill() or obj.bfill() instead.\n","  df_ffill = df.fillna(method='ffill')\n"]}]},{"cell_type":"code","source":["# Strategy 4: Custom fill per column\n","print('\\n=== STRATEGY 4: CUSTOM FILL ===')\n","df_custom = df.fillna({\n","    'Crop': 'Unknown',\n","    'Yield_tons': df['Yield_tons'].median(),\n","    'Rainfall_mm': 650,  # Regional average\n","    'Fertilizer_kg': 150,  # Standard recommendation\n","    'Soil_pH': 6.3  # Neutral pH\n","})\n","print(df_custom)\n","\n","print('\\n=== VERIFICATION ===')\n","print(f'Missing values after treatment: {df_custom.isna().sum().sum()}')\n","\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5IVjS2aXmpOZ","executionInfo":{"status":"ok","timestamp":1771818389897,"user_tz":-330,"elapsed":22,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"784341ea-6221-412f-d54d-45ea8078b996"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 4: CUSTOM FILL ===\n","  Farm_ID     Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001    Wheat       180.0        450.0          120.0      6.5\n","1    F002     Rice       204.0        820.0          150.0      5.8\n","2    F003  Unknown       416.0        650.0          200.0      6.2\n","3    F004    Wheat       164.0        420.0          150.0      6.7\n","4    F005     Corn       204.0        710.0          195.0      6.3\n","5    F006     Rice       228.0        850.0          160.0      5.9\n","\n","=== VERIFICATION ===\n","Missing values after treatment: 0\n"]}]},{"cell_type":"code","source":["})\n","import pandas as pd\n","\n","# Multi-year farm data\n","data = {\n","    'Year': [2020, 2020, 2020, 2021, 2021, 2021, 2022, 2022, 2022, 2023, 2023, 2023],\n","    'Region': ['North', 'South', 'East', 'North', 'South', 'East',\n","               'North', 'South', 'East', 'North', 'South', 'East'],\n","    'Crop': ['Wheat', 'Rice', 'Corn', 'Wheat', 'Rice', 'Corn',\n","             'Wheat', 'Rice', 'Corn', 'Wheat', 'Rice', 'Corn'],\n","    'Yield_tons': [180, 228, 416, 195, 245, 430, 210, 250, 445, 225, 260, 455],\n","    'Area_ha': [50, 45, 55, 52, 46, 56, 54, 48, 57, 55, 49, 58],\n","    'Cost_thousands': [85, 95, 180, 90, 100, 190, 95, 105, 195, 100, 110, 200]\n","}\n","\n","df = pd.DataFrame(data)\n","\n","print('Agricultural Dataset:')\n","print(df)\n"],"metadata":{"id":"WO53E4SsnN_p"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Group by Region\n","print('\\n=== ANALYSIS BY REGION ===')\n","region_stats = df.groupby('Region').agg({\n","    'Yield_tons': ['sum', 'mean', 'std'],\n","    'Area_ha': 'sum',\n","    'Cost_thousands': 'sum'\n","})\n","print(region_stats)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"H7o7skklnhjB","executionInfo":{"status":"ok","timestamp":1771818697501,"user_tz":-330,"elapsed":53,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"d64608a5-d632-44c0-defd-f6f6901bc4e6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== ANALYSIS BY REGION ===\n","       Yield_tons                    Area_ha Cost_thousands\n","              sum    mean        std     sum            sum\n","Region                                                     \n","East         1746  436.50  17.097758     226            765\n","North         810  202.50  19.364917     211            370\n","South         983  245.75  13.375973     188            410\n"]}]},{"cell_type":"code","source":["# Pivot table\n","print('\\n=== PIVOT TABLE: Average Yield by Region and Crop ===')\n","pivot = df.pivot_table(values='Yield_tons',\n","                       index='Region',\n","                       columns='Crop',\n","                       aggfunc='mean').round(2)\n","print(pivot)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"seZ8QppVpSUI","executionInfo":{"status":"ok","timestamp":1771819088745,"user_tz":-330,"elapsed":51,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"3e5404d1-d5ee-435f-e279-41d36fda7818"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== PIVOT TABLE: Average Yield by Region and Crop ===\n","Crop     Corn    Rice  Wheat\n","Region                      \n","East    436.5     NaN    NaN\n","North     NaN     NaN  202.5\n","South     NaN  245.75    NaN\n"]}]},{"cell_type":"code","source":["# Filter groups with high performance\n","print('\\n=== HIGH PERFORMING REGIONS (Avg Yield > 300) ===')\n","high_regions = df.groupby('Region').filter(lambda x: x['Yield_tons'].mean() > 300)\n","print(high_regions[['Region', 'Crop', 'Yield_tons']].drop_duplicates('Region'))\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"k53ti_9lpc-h","executionInfo":{"status":"ok","timestamp":1771819115494,"user_tz":-330,"elapsed":8,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"71696364-74ab-4b65-9a5c-c5f542a03afd"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== HIGH PERFORMING REGIONS (Avg Yield > 300) ===\n","  Region  Crop  Yield_tons\n","2   East  Corn         416\n"]}]},{"cell_type":"code","source":["# Transform: Add group mean to each row\n","df['Region_Avg_Yield'] = df.groupby('Region')['Yield_tons'].transform('mean').round(2)\n","df['Crop_Avg_Yield'] = df.groupby('Crop')['Yield_tons'].transform('mean').round(2)\n","\n","print('\\n=== DATASET WITH GROUP AVERAGES ===')\n","print(df[['Year', 'Region', 'Crop', 'Yield_tons',\n","          'Region_Avg_Yield', 'Crop_Avg_Yield']].head(6))\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"OWKWcdcLpJjR","executionInfo":{"status":"ok","timestamp":1771819043505,"user_tz":-330,"elapsed":22,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"1fc5d6f7-b422-4c30-c021-911763e23871"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== DATASET WITH GROUP AVERAGES ===\n","   Year Region   Crop  Yield_tons  Region_Avg_Yield  Crop_Avg_Yield\n","0  2020  North  Wheat         180            202.50          202.50\n","1  2020  South   Rice         228            245.75          245.75\n","2  2020   East   Corn         416            436.50          436.50\n","3  2021  North  Wheat         195            202.50          202.50\n","4  2021  South   Rice         245            245.75          245.75\n","5  2021   East   Corn         430            436.50          436.50\n"]}]},{"cell_type":"code","source":["# Year-over-year growth\n","print('\\n=== YEARLY TRENDS ===')\n","yearly = df.groupby('Year').agg({\n","    'Yield_tons': 'sum',\n","    'Area_ha': 'sum'\n","})\n","yearly['Yield_per_ha'] = (yearly['Yield_tons'] / yearly['Area_ha']).round(2)\n","print(yearly)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZuNRlSblpBcJ","executionInfo":{"status":"ok","timestamp":1771819005608,"user_tz":-330,"elapsed":41,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"7d44ae47-247f-4bb5-d5d5-49039b40d7f3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== YEARLY TRENDS ===\n","      Yield_tons  Area_ha  Yield_per_ha\n","Year                                   \n","2020         824      150          5.49\n","2021         870      154          5.65\n","2022         905      159          5.69\n","2023         940      162          5.80\n"]}]},{"cell_type":"code","source":["# Multiple grouping (Region and Crop)\n","print('\\n=== REGION-CROP ANALYSIS ===')\n","region_crop = df.groupby(['Region', 'Crop'])['Yield_tons'].mean().round(2)\n","print(region_crop)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Pr5Q3ozzoGMJ","executionInfo":{"status":"ok","timestamp":1771818764986,"user_tz":-330,"elapsed":38,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"34028bb1-d838-4343-f87c-92e694fd7826"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== REGION-CROP ANALYSIS ===\n","Region  Crop \n","East    Corn     436.50\n","North   Wheat    202.50\n","South   Rice     245.75\n","Name: Yield_tons, dtype: float64\n"]}]},{"cell_type":"code","source":["# Group by Crop\n","print('\\n=== ANALYSIS BY CROP ===')\n","crop_stats = df.groupby('Crop').agg({\n","    'Yield_tons': ['mean', 'min', 'max'],\n","    'Cost_thousands': 'mean'\n","}).round(2)\n","print(crop_stats)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"F09ca5yun9Rv","executionInfo":{"status":"ok","timestamp":1771818732362,"user_tz":-330,"elapsed":52,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"12a01cc2-5567-4744-97fc-5e848ace7c5d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== ANALYSIS BY CROP ===\n","      Yield_tons           Cost_thousands\n","            mean  min  max           mean\n","Crop                                     \n","Corn      436.50  416  455         191.25\n","Rice      245.75  228  260         102.50\n","Wheat     202.50  180  225          92.50\n"]}]},{"cell_type":"code","source":["print('\\n=== MISSING VALUE ANALYSIS ===')\n","print('\\nMissing values per column:')\n","print(df.isna().sum())\n","print(f'\\nTotal missing values: {df.isna().sum().sum()}')\n","print(f'Percentage of missing data: {(df.isna().sum().sum() / df.size * 100):.2f}%')\n","\n","print('\\n=== ROWS WITH MISSING DATA ===')\n","rows_with_missing = df[df.isna().any(axis=1)]\n","print(rows_with_missing)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"gfeqIYA9mL-z","executionInfo":{"status":"ok","time