{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyO6k6StuT13YqgWpi6hvZeC"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":4,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"aC0bhGk1g4fS","executionInfo":{"status":"ok","timestamp":1770876741230,"user_tz":-330,"elapsed":24,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"0123a1ca-a03d-4399-825c-64d7b07d2de4"},"outputs":[{"output_type":"stream","name":"stdout","text":["Nutrient Requirements (Kg/ha):\n","[[120  60  80]\n"," [150  75 100]\n"," [100  50  70]]\n","\n"," fertilizer composition(%):\n","[[0.2  0.1  0.15]\n"," [0.15 0.2  0.1 ]\n"," [0.1  0.15 0.25]]\n","\n"," transposed nutrient needs(nutrients*crops):\n","[[120 150 100]\n"," [ 60  75  50]\n"," [ 80 100  70]]\n","\n"," total nutrients needed per crop:[260 325 220]kg/ha\n","\n"," Nutrients from 100kg each fertilizer:[45. 45. 50.]\n","\n"," determinant of fertilizer matrix:0.004625\n","\n"," enhanced nutrient needs(10% increase):\n","[[132.   66.   88. ]\n"," [165.   82.5 110. ]\n"," [110.   55.   77. ]]\n"]}],"source":["import numpy as np\n","#nutrient requirements for 3 crops(N,P,K IN Kg/ha)\n","#Rows:crops(Wheat,Corn,Rice)\n","#Columns:Nutrients(Nitrogen,Phosphorus,Potassium)\n","\n","nutrients_needs=np.array([\n","    [120,60,80],   #Wheat\n","    [150,75,100],  #Corn\n","    [100,50,70]    #Rice\n","])\n","\n","#Available fertilizer composition(percentage of N,P,K)\n","#Rows:fertilizer types\n","#columns:Nutrient content\n","fertilizer_composition=np.array([\n","     [0.20,0.10,0.15],   #Type A:20%N,10%P,15%K\n","     [0.15,0.20,0.10],   #Type B:15%N,20%P,10%K\n","     [0.10,0.15,0.25]   #Type C:10%N,15%P,25%K\n"," ])\n","\n","print('Nutrient Requirements (Kg/ha):')\n","print(nutrients_needs)\n","print('\\n fertilizer composition(%):')\n","print(fertilizer_composition)\n","\n","#matrix transpose example\n","print('\\n transposed nutrient needs(nutrients*crops):')\n","print(nutrients_needs.T)\n","\n","#Calculate fertilizer amounts(solving system of equations)\n","#This would normally require optimization,but for demonstration:\n","total_nutrients_per_crop=np.sum(nutrients_needs,axis=1)\n","print(f'\\n total nutrients needed per crop:{total_nutrients_per_crop}kg/ha')\n","\n","#Matrix multipication:calculate total nutrient delivery\n","#if we apply 100kg of each fertilizer type\n","fertilizer_application=np.array([100,100,100]) #kg of each type\n","\n","nutrients_delivered=np.dot(fertilizer_application,fertilizer_composition)\n","print(f'\\n Nutrients from 100kg each fertilizer:{nutrients_delivered}')\n","\n","#calculate determinant(for checking if matrix is invertible)\n","det=np.linalg.det(fertilizer_composition)\n","print(f'\\n determinant of fertilizer matrix:{det:6f}')\n","\n","#identify matrix example(scaling factor)\n","scaling=np.eye(3)*1.1  #10% increase\n","enhanced_needs=np.dot(nutrients_needs,scaling)\n","print('\\n enhanced nutrient needs(10% increase):')\n","print(enhanced_needs)"]}]}