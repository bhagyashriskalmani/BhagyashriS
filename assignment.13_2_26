{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNg1HQzgvyKnrvy1MwWdHfw"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import numpy as np\n","n=int(input(\"Enter the number of months\")) #12\n","#Rainfall data over 12 months\n","rainfall_data=[]\n","\n","for i in range(n):\n","  data=float(input(\"Enter rainfall(mm)\"))\n","  rainfall_data.append(data)\n","rainfall=np.array([rainfall_data])\n","\n","print(rainfall)\n","\n","#yield data over 12 months\n","yield_info=[]\n","for i in range(n):\n","  yield_data=float(input(\"Enter yield(q/acre):\"))\n","  yield_info.append(yield_data)\n","yield_data=np.array([yield_info])\n","print(yield_data)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"71A_wmUtW5hn","executionInfo":{"status":"ok","timestamp":1770959967305,"user_tz":-330,"elapsed":1212840,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"a1494015-6b8d-42a5-956e-77b553fc9c11"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Enter the number of months12\n","Enter rainfall(mm)30\n","Enter rainfall(mm)31\n","Enter rainfall(mm)32\n","Enter rainfall(mm)33\n","Enter rainfall(mm)34\n","Enter rainfall(mm)40\n","Enter rainfall(mm)31\n","Enter rainfall(mm)28\n","Enter rainfall(mm)27\n","Enter rainfall(mm)26\n","Enter rainfall(mm)25\n","Enter rainfall(mm)24\n","[[30. 31. 32. 33. 34. 40. 31. 28. 27. 26. 25. 24.]]\n","Enter yield(q/acre):12\n","Enter yield(q/acre):13\n","Enter yield(q/acre):14\n","Enter yield(q/acre):15\n","Enter yield(q/acre):16\n","Enter yield(q/acre):20\n","Enter yield(q/acre):18\n","Enter yield(q/acre):16\n","Enter yield(q/acre):15\n","Enter yield(q/acre):14\n","Enter yield(q/acre):13\n","Enter yield(q/acre):12\n","[[12. 13. 14. 15. 16. 20. 18. 16. 15. 14. 13. 12.]]\n"]}]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770960254716,"user_tz":-330,"elapsed":12,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"3ba55802-0ada-48c6-c9c7-02e7ba2ef6bd","id":"Iaj1oIoWVfiu"},"outputs":[{"output_type":"stream","name":"stdout","text":["====Rainfall Statistics===\n","mean:30.08mm\n","median:30.50mm\n","Std Dev:4.29mm\n","variance:18.41\n","min:24.0mm(month12)\n","max:40.0mm(month6)\n","range:16.0mm\n","\n","===yield statistics===\n","mean:14.83q/acre\n","median:14.50q/acre\n","Std Dev:2.30q/acre\n","\n","===Percentiles===\n","25th percentile rainfall:26.750000mm\n","50th percentile rainfall:30.500000mm\n","75th percentile rainfall:32.250000mm\n","90th percentile rainfall:33.900000mm\n","\n","===correlation analysis===\n","rainfall_yield correlation:0.701260\n","Interpretation:strong positive correlation\n","\n","===CUMULATIVE RAINFALL===\n","month\t rainfall\t cumulative\n","1\t[30. 31. 32. 33. 34. 40. 31. 28. 27. 26. 25. 24.]\t\t30.0\n","\n","===CUMULATIVE YIELD===\n","month\t yield_data\t cumulative\n","1\t[12. 13. 14. 15. 16. 20. 18. 16. 15. 14. 13. 12.]\t\t12.0\n"]}],"source":["\n","\n","print('====Rainfall Statistics===')\n","print(f'mean:{np.mean(rainfall):.2f}mm')\n","print(f'median:{np.median(rainfall):.2f}mm')\n","print(f'Std Dev:{np.std(rainfall):.2f}mm')\n","print(f'variance:{np.var(rainfall):.2f}')\n","print(f'min:{np.min(rainfall)}mm(month{np.argmin(rainfall)+1})')\n","print(f'max:{np.max(rainfall)}mm(month{np.argmax(rainfall)+1})')\n","print(f'range:{np.ptp(rainfall)}mm')\n","\n","\n","\n","print('\\n===yield statistics===')\n","print(f'mean:{np.mean(yield_data):.2f}q/acre')\n","print(f'median:{np.median(yield_data):.2f}q/acre')\n","print(f'Std Dev:{np.std(yield_data):.2f}q/acre')\n","\n","print('\\n===Percentiles===')\n","percentiles=[25,50,75,90]\n","rainfall_percentiles=np.percentile(rainfall,percentiles)\n","for p,val in zip(percentiles,rainfall_percentiles):\n","  print(f'{p}th percentile rainfall:{val:2f}mm')\n","\n","\n","print('\\n===correlation analysis===')\n","correlation_matrix=np.corrcoef(rainfall,yield_data)\n","correlation=correlation_matrix[0,1]\n","print(f'rainfall_yield correlation:{correlation:4f}')\n","print('Interpretation:strong positive correlation'if correlation>0.7 else'moderate correlation'if correlation>0.4 else 'weak correlation')\n","\n","print('\\n===CUMULATIVE RAINFALL===')\n","cumulative=np.cumsum(rainfall)\n","print('month\\t rainfall\\t cumulative')\n","for month,(rain,cum )in enumerate(zip(rainfall,cumulative),1):\n"," print(f'{month}\\t{rain}\\t\\t{cum}')\n","\n"," print('\\n===CUMULATIVE YIELD===')\n","cumulative=np.cumsum(yield_data)\n","print('month\\t yield_data\\t cumulative')\n","for month,(yield_data,cum )in enumerate(zip(yield_data,cumulative),1):\n"," print(f'{month}\\t{yield_data}\\t\\t{cum}')\n","\n"]},{"cell_type":"code","source":["import numpy as np\n","n=int(input(\"Enter the number of sem\")) #8\n","#student_marks data over 8 sem\n","student_marks_data=[]\n","\n","for i in range(n):\n","  data=float(input(\"Enter student_marks(CGPA)\"))\n","  student_marks_data.append(data)\n","student_marks=np.array([student_marks_data])\n","\n","print(student_marks)\n","\n","print('====STUDENT_MARKS Statistics===')\n","print(f'mean:{np.mean(student_marks):.2f}CGPA')\n","print(f'median:{np.median(student_marks):.2f}CGPA')\n","print(f'Std Dev:{np.std(student_marks):.2f}CGPA')\n","print(f'variance:{np.var(student_marks):.2f}')\n","print(f'min:{np.min(student_marks)}CGPA(sem{np.argmin(student_marks)+1})')\n","print(f'max:{np.max(student_marks)}CGPA(sem{np.argmax(student_marks)+1})')\n","print(f'range:{np.ptp(student_marks)}CGPA')\n","\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"eTYtGVodx6i0","executionInfo":{"status":"ok","timestamp":1771218098175,"user_tz":-330,"elapsed":60247,"user":{"displayName":"Bhagyashri S Kalmani","userId":"033238281815371968