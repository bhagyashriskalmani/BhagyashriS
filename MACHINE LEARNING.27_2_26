ectare): 4.19\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/sklearn/utils/validation.py:2739: UserWarning: X does not have valid feature names, but LinearRegression was fitted with feature names\n","  warnings.warn(\n"]}]},{"cell_type":"code","source":["#step1:Import Libraries\n","import numpy as np\n","import pandas as pd\n","from sklearn.model_selection import train_test_split\n","from sklearn.linear_model import LinearRegression\n","from sklearn.metrics import mean_absolute_error,r2_score\n","\n","#step 2:Create sample agricultural dataset\n","data={\n","    \"Rainfall\":[450,520,390,610,480,530,410,590],\n","    \"Temperature\":[22,20,25,19,23,21,24,18],\n","    \"Nitrogen\":[0.8,1.0,0.6,1.2,0.9,1.1,0.7,1.3],\n","    \"Fertilizer\":[120,140,100,160,130,150,110,170],\n","    \"Yield\":[3.5,4.2,2.9,4.8,3.8,4.4,3.1,5.0]\n","}\n","df=pd.DataFrame(data)\n","\n","#step3:DEFINE FEATURES(X) AND TARGET(Y)\n","x=df[[\"Rainfall\",\"Temperature\",\"Nitrogen\",\"Fertilizer\"]]\n","y=df[[\"Yield\"]]\n","print(x)\n","print(y)\n","#Step 4:Split Data into Training and Testing Sets\n","x_train,x_test,y_train,y_test=train_test_split(x,y,test_size=0.25,random_state=30)\n","print(x_train)\n","print(x_test)\n","#STEP 5:Train Model\n","model=LinearRegression()\n","model.fit(x_train,y_train)\n","\n","#step 6:Make predictions\n","y_pred=model.predict(x_test)\n","\n","#step 7:Evaluate Model\n","mae=mean_absolute_error=(y_test,y_pred)\n","r2=r2_score(y_test,y_pred)\n","\n","print(\"Mean_Absolute_Error:\",(mae,2))\n","print(\"R2 Score:\",(r2,2))\n","\n","#Step8:Predict Yield for new farm conditions\n","new_data=np.array([[500,21,1.0,145]])   #rainfall,temp,nitrogen,fertilizer\n","predicted_yield=model.predict(new_data)\n","\n","print(\"Predicted Yield(tons/hectare):\",(predicted_yield[0],2))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"3A9lM2swurmN","executionInfo":{"status":"ok","timestamp":1772172873569,"user_tz":-330,"elapsed":28,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"4047c21f-a03c-4a04-cbd3-325082d6ac5f"},"execution_count":29,"outputs":[{"output_type":"stream","name":"stdout","text":["   Rainfall  Temperature  Nitrogen  Fertilizer\n","0       450           22       0.8         120\n","1       520           20       1.0         140\n","2       390           25       0.6         100\n","3       610           19       1.2         160\n","4       480           23       0.9         130\n","5       530           21       1.1         150\n","6       410           24       0.7         110\n","7       590           18       1.3         170\n","   Yield\n","0    3.5\n","1    4.2\n","2    2.9\n","3    4.8\n","4    3.8\n","5    4.4\n","6    3.1\n","7    5.0\n","   Rainfall  Temperature  Nitrogen  Fertilizer\n","2       390           25       0.6         100\n","0       450           22       0.8         120\n","4       480           23       0.9         130\n","6       410           24       0.7         110\n","7       590           18       1.3         170\n","5       530           21       1.1         150\n","   Rainfall  Temperature  Nitrogen  Fertilizer\n","3       610           19       1.2         160\n","1       520           20       1.0         140\n","Mean_Absolute_Error: ((   Yield\n","3    4.8\n","1    4.2, array([[5.04859813],\n","       [4.20093458]])), 2)\n","R2 Score: (0.6566560883531847, 2)\n","Predicted Yield(tons/hectare): (array([4.11167715]), 2)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/sklearn/utils/validation.py:2739: UserWarning: X does not have valid feature names, but LinearRegression was fitted with feature names\n","  warnings.warn(\n"]}]}]}