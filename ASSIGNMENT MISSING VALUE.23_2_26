_ffill)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"KMaw0ZiZmiBp","executionInfo":{"status":"ok","timestamp":1771818353968,"user_tz":-330,"elapsed":62,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"1a3fde98-3091-415e-aa03-b141095459fb"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 3: FORWARD FILL ===\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001  Wheat       180.0        450.0          120.0      6.5\n","1    F002   Rice       180.0        820.0          150.0      5.8\n","2    F003   Rice       416.0        820.0          200.0      6.2\n","3    F004  Wheat       164.0        420.0          200.0      6.7\n","4    F005   Corn       164.0        710.0          195.0      6.7\n","5    F006   Rice       228.0        850.0          160.0      5.9\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-3212914461.py:3: FutureWarning: DataFrame.fillna with 'method' is deprecated and will raise in a future version. Use obj.ffill() or obj.bfill() instead.\n","  df_ffill = df.fillna(method='ffill')\n"]}]},{"cell_type":"code","source":["# Strategy 4: Custom fill per column\n","print('\\n=== STRATEGY 4: CUSTOM FILL ===')\n","df_custom = df.fillna({\n","    'Crop': 'Unknown',\n","    'Yield_tons': df['Yield_tons'].median(),\n","    'Rainfall_mm': 650,  # Regional average\n","    'Fertilizer_kg': 150,  # Standard recommendation\n","    'Soil_pH': 6.3  # Neutral pH\n","})\n","print(df_custom)\n","\n","print('\\n=== VERIFICATION ===')\n","print(f'Missing values after treatment: {df_custom.isna().sum().sum()}')\n","\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5IVjS2aXmpOZ","executionInfo":{"status":"ok","timestamp":1771818389897,"user_tz":-330,"elapsed":22,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"784341ea-6221-412f-d54d-45ea8078b996"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 4: CUSTOM FILL ===\n","  Farm_ID     Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","0    F001    Wheat       180.0        450.0          120.0      6.5\n","1    F002     Rice       204.0        820.0          150.0      5.8\n","2    F003  Unknown       416.0        650.0          200.0      6.2\n","3    F004    Wheat       164.0        420.0          150.0      6.7\n","4    F005     Corn       204.0        710.0          195.0      6.3\n","5    F006     Rice       228.0        850.0          160.0      5.9\n","\n","=== VERIFICATION ===\n","Missing values after treatment: 0\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","\n","# Multi-year farm data\n","data = {\n","    'Year': [2020, 2020, 2020, 2021, 2021, 2021, 2022, 2022, 2022, 2023, 2023, 2023],\n","    'Region': ['North', 'South', 'East', 'North', 'South', 'East',\n","               'North', 'South', 'East', 'North', 'South', 'East'],\n","    'Crop': ['Wheat', 'Rice', 'Corn', 'Wheat', 'Rice', 'Corn',\n","             'Wheat', 'Rice', 'Corn', 'Wheat', 'Rice', 'Corn'],\n","    'Yield_tons': [180, 228, 416, 195, 245, 430, 210, 250, 445, 225, 260, 455],\n","    'Area_ha': [50, 45, 55, 52, 46, 56, 54, 48, 57, 55, 49, 58],\n","    'Cost_thousands': [85, 95, 180, 90, 100, 190, 95, 105, 195, 100, 110, 200]\n","}\n","\n","df = pd.DataFrame(data)\n","\n","print('Agricultural Dataset:')\n","print(df)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"WO53E4SsnN_p","executionInfo":{"status":"ok","timestamp":1771823955099,"user_tz":-330,"elapsed":23,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"1fb21b4e-34ff-4615-ce6f-91a2ffda9c08"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Agricultural Dataset:\n","    Year Region   Crop  Yield_tons  Area_ha  Cost_thousands\n","0   2020  North  Wheat         180       50              85\n","1   2020  South   Rice         228       45              95\n","2   2020   East   Corn         416       55             180\n","3   2021  North  Wheat         195       52              90\n","4   2021  South   Rice         245       46             100\n","5   2021   East   Corn         430       56             190\n","6   2022  North  Wheat         210       54              95\n","7   2022  South   Rice         250       48             105\n","8   2022   East   Corn         445       57             195\n","9   2023  North  Wheat         225       55             100\n","10  2023  South   Rice         260       49             110\n","11  2023   East   Corn         455       58             200\n"]}]},{"cell_type":"code","source":["# Group by Region\n","print('\\n=== ANALYSIS BY REGION ===')\n","region_stats = df.groupby('Region').agg({\n","    'Yield_tons': ['sum', 'mean', 'std'],\n","    'Area_ha': 'sum',\n","    'Cost_thousands': 'sum'\n","})\n","print(region_stats)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"H7o7skklnhjB","executionInfo":{"status":"ok","timestamp":1771818697501,"user_tz":-330,"elapsed":53,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"d64608a5-d632-44c0-defd-f6f6901bc4e6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== ANALYSIS BY REGION ===\n","       Yield_tons                    Area_ha Cost_thousands\n","              sum    mean        std     sum            sum\n","Region                                                     \n","East         1746  436.50  17.097758     226            765\n","North         810  202.50  19.364917     211            370\n","South         983  245.75  13.375973     188            410\n"]}]},{"cell_type":"code","source":["# Group by Crop\n","print('\\n=== ANALYSIS BY CROP ===')\n","crop_stats = df.groupby('Crop').agg({\n","    'Yield_tons': ['mean', 'min', 'max'],\n","    'Cost_thousands': 'mean'\n","}).round(2)\n","print(crop_stats)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"F09ca5yun9Rv","executionInfo":{"status":"ok","timestamp":1771818732362,"user_tz":-330,"elapsed":52,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"12a01cc2-5567-4744-97fc-5e848ace7c5d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== ANALYSIS BY CROP ===\n","      Yield_tons           Cost_thousands\n","            mean  min  max           mean\n","Crop                                     \n","Corn      436.50  416  455         191.25\n","Rice      245.75  228  260         102.50\n","Wheat     202.50  180  225          92.50\n"]}]},{"cell_type":"code","source":["# Multiple grouping (Region and Crop)\n","print('\\n=== REGION-CROP ANALYSIS ===')\n","region_crop = df.groupby(['Region', 'Crop'])['Yield_tons'].mean().round(2)\n","print(region_crop)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Pr5Q3ozzoGMJ","executionInfo":{"status":"ok","timestamp":1771818764986,"user_tz":-330,"elapsed":38,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"34028bb1-d838-4343-f87c-92e694fd7826"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== REGION-CROP ANALYSIS ===\n","Region  Crop \n","East    Corn     436.50\n","North   Wheat    202.50\n","South   Rice     245.75\n","Name: Yield_tons, dtype: float64\n"]}]},{"cell_type":"code","source":["# Year-over-year growth\n","print('\\n=== YEARLY TRENDS ===')\n","yearly = df.groupby('Year').agg({\n","    'Yield_tons': 'sum',\n","    'Area_ha': 'sum'\n","})\n","yearly['Yield_per_ha'] = (yearly['Yield_tons'] / yearly['Area_ha']).round(2)\n","print(yearly)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZuNRlSblpBcJ","executionInfo":{"status":"ok","timestamp":1771819005608,"user_tz":-330,"elap