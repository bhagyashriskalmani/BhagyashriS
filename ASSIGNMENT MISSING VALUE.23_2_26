# Agricultural data with missing values\n","data = {\n","    'Farm_ID': ['F001', 'F002', 'F003', 'F004', 'F005', 'F006'],\n","    'Crop': ['Wheat', 'Rice', np.nan, 'Wheat', 'Corn', 'Rice'],\n","    'Yield_tons': [180, np.nan, 416, 164, np.nan, 228],\n","    'Rainfall_mm': [450, 820, np.nan, 420, 710, 850],\n","    'Fertilizer_kg': [120, 150, 200, np.nan, 195, 160],\n","    'Soil_pH': [6.5, 5.8, 6.2, 6.7, np.nan, 5.9]\n","}\n","\n","df = pd.DataFrame(data)\n","\n","print('Original Data with Missing Values:')\n","print(df)\n","\n","\n"]},{"cell_type":"code","source":["# Filter groups with high performance\n","print('\\n=== HIGH PERFORMING REGIONS (Avg Yield > 300) ===')\n","high_regions = df.groupby('Region').filter(lambda x: x['Yield_tons'].mean() > 300)\n","print(high_regions[['Region', 'Crop', 'Yield_tons']].drop_duplicates('Region'))\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1771819115494,"user_tz":-330,"elapsed":8,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"71696364-74ab-4b65-9a5c-c5f542a03afd","id":"88zeBYD7wI-M"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== HIGH PERFORMING REGIONS (Avg Yield > 300) ===\n","  Region  Crop  Yield_tons\n","2   East  Corn         416\n"]}]},{"cell_type":"code","source":["print('\\n=== MISSING VALUE ANALYSIS ===')\n","print('\\nMissing values per column:')\n","print(df.isna().sum())\n","print(f'\\nTotal missing values: {df.isna().sum().sum()}')\n","print(f'Percentage of missing data: {(df.isna().sum().sum() / df.size * 100):.2f}%')\n","\n","print('\\n=== ROWS WITH MISSING DATA ===')\n","rows_with_missing = df[df.isna().any(axis=1)]\n","print(rows_with_missing)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"gfeqIYA9mL-z","executionInfo":{"status":"ok","timestamp":1771818268822,"user_tz":-330,"elapsed":22,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"eba15ccb-75aa-4a28-8e72-21bfa5923dd7"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== MISSING VALUE ANALYSIS ===\n","\n","Missing values per column:\n","Farm_ID          0\n","Crop             1\n","Yield_tons       2\n","Rainfall_mm      1\n","Fertilizer_kg    1\n","Soil_pH          1\n","dtype: int64\n","\n","Total missing values: 6\n","Percentage of missing data: 16.67%\n","\n","=== ROWS WITH MISSING DATA ===\n","  Farm_ID   Crop  Yield_tons  Rainfall_mm  Fertilizer_kg  Soil_pH\n","1    F002   Rice         NaN        820.0          150.0      5.8\n","2    F003    NaN       416.0          NaN          200.0      6.2\n","3    F004  Wheat       164.0        420.0            NaN      6.7\n","4    F005   Corn         NaN        710.0          195.0      NaN\n"]}]},{"cell_type":"code","source":["# Strategy 1: Drop rows with missing values\n","print('\\n=== STRATEGY 1: DROP MISSING ROWS ===')\n","df_dropped = df.dropna()\n","print(f'Original shape: {df.shape}')\n","print(f'After dropping: {df_dropped.shape}')\n","print(df_dropped)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vSkCAypjwjBu","executionInfo":{"status":"ok","timestamp":1771820967658,"user_tz":-330,"elapsed":26,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"843c8985-627d-46cf-b2bb-534e5897ce6c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== STRATEGY 1: DROP MISSING ROWS ===\n","Original shape: (12, 8)\n","After dropping: (12, 8)\n","    Year Region   Crop  Yield_tons  Area_ha  Cost_thousands  Region_Avg_Yield  \\\n","0   2020  North  Wheat         180       50              85            202.50   \n","1   2020  South   Rice         228       45              95            245.75   \n","2   2020   East   Corn         416       55             180            436.50   \n","3   2021  North  Wheat         195       52              90            202.50   \n","4   2021  South   Rice         245       46             100            245.75   \n","5   2021   East   Corn         430       56             190            436.50   \n","6   2022  North  Wheat         210       54              95            202.50   \n","7   2022  South   Rice         250       48             105            245.75   \n","8   2022   East   Corn         445       57             195            436.50   \n","9   2023  North  Wheat         225       55             100            202.50   \n","10  2023  South   Rice         260       49             110            245.75   \n","11  2023   East   Corn         455       58             200            436.50   \n","\n","    Crop_Avg_Yield  \n","0           202.50  \n","1           245.75  \n","2           436.50  \n","3           202.50  \n","4           245.75  \n","5           436.50  \n","6           202.50  \n","7           245.75  \n","8           436.50  \n","9           202.50  \n","10          245.75  \n","11          436.50  \n"]}]},{"cell_type":"code","source":["# Strategy 2: Fill with mean/median\n","print('\\n=== STRATEGY 2: FILL WITH STATISTICS ===')\n","df_filled = df.copy()\n","# Fill numeric columns with mean\n","df_filled['Yield_tons'].fillna(df_filled['Yield_tons'].mean(), inplace=True)\n","df_filled['Rainfall_mm'].fillna(df_filled['Rainfall_mm'].median(), inplace=True)\n","df_filled['Fertilizer_kg'].fillna(df_filled['Fertilizer_kg'].mean(), inplace=True)\n","df_filled['Soil_pH'].fillna(df_filled['Soil_pH'].mean(), inplace=True)\n","# Fill categorical with mode\n","df_filled['Crop'].fillna(df_filled['Crop'].mode()[0], inplace=True)\n","print(df_filled)\n","\n"],"metadata":{"id":"hWogDBz0BMw7","executionInfo":{"status":"error","timestamp":1771825344961,"user_tz":-330,"elapsed":142,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"a7efbef8-a685-447e-ccbd-d3489ce7ba55","colab":{"base_uri":"https://localho