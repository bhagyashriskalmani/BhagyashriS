{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNHk6Xay2hMgOgi/xcHSgQq"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GiGdldCpJJ1r","executionInfo":{"status":"ok","timestamp":1772599724580,"user_tz":-330,"elapsed":1747,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"d3201a03-996a-4ceb-d5a5-e59839d4790a"},"outputs":[{"output_type":"stream","name":"stdout","text":["      Rainfall  Fertilizer  Temperature      Yield\n","0   699.632095  251.860039    33.987796  10.827216\n","1  1160.571445  274.022825    34.216786   8.126232\n","2   985.595153  129.500869    33.552695   9.723799\n","3   878.926787   77.512981    24.292698   0.386578\n","4   524.814912  106.983791    18.262762   3.703742\n"]}],"source":["#step 1:Creating a farm dataset\n","import numpy as np\n","import pandas as pd\n","\n","np.random.seed(42)\n","#generate synthetic farming data\n","n=120\n","\n","rainfall=np.random.uniform(400,1200,n)  #mm\n","fertilizer=np.random.uniform(50,300,n)  #kg\n","temperature=np.random.uniform(18,35,n)  #celsius\n","\n","#True relationship(unknown to model)\n","yield_tons=(0.005*rainfall+0.03*fertilizer-0.1*temperature+np.random.normal(0,2,n)) #noise\n","\n","data=pd.DataFrame({\n","    \"Rainfall\":rainfall,\n","    \"Fertilizer\":fertilizer,\n","    \"Temperature\":temperature,\n","    \"Yield\":yield_tons\n","})\n","\n","print(data.head())"]},{"cell_type":"code","source":["#Step 2:split into Train,Validation,Test 70% Train,15% Validation,15% Test\n","from sklearn.model_selection import train_test_split\n","x=data[[\"Rainfall\",\"Fertilizer\",\"Temperature\"]]\n","y=data[\"Yield\"]\n","\n","#First split:Train(70%) and Temp (30%)\n","x_train,x_temp,y_train,y_temp=train_test_split(x,y,test_size=0.30,random_state=1)\n","\n","#second split:validation(15%) and Test(15%)\n","x_val,x_test,y_val,y_test=train_test_split(x_temp,y_temp,test_size=0.50,random_state=1)\n","\n","\n","print(\"Training set:\",x_train.shape)\n","print(\"Validation:\",x_val.shape)\n","print(\"Test set:\",x_test.shape)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IAu7olU-LVMx","executionInfo":{"status":"ok","timestamp":1772600838524,"user_tz":-330,"elapsed":4,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"bbf8077b-338f-4675-cbf1-f6cfc56a31d6"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["Training set: (84, 3)\n","Validation: (18, 3)\n","Test set: (18, 3)\n"]}]},{"cell_type":"code","source":["#STEP 3:Train Regression model\n","from sklearn.linear_model import LinearRegression\n","\n","model=LinearRegression()\n","model.fit(x_train,y_train)\n","\n","#STEP 4:EVALUATE USING REGRESSION METRICS\n","from sklearn.metrics import mean_absolute_error,mean_squared_error,r2_score\n","\n","def evaluate_model(x,y,name):\n","  y_pred=model.predict(x)\n","  mae=mean_absolute_error(y,y_pred)\n","  mse=mean_squared_error(y,y_pred)\n","  rmse=np.sqrt(mse)\n","  r2=r2_score(y,y_pred)\n","\n","  print(f\"\\n{name} set performance\")\n","  print(\"MAE:\",mae)\n","  print(\"MSE:\",mse)\n","  print(\"RMSE:\",rmse)\n","  print(\"R2:\",r2)\n","\n","evaluate_model(x_train,y_train,\"Training\")\n","evaluate_model(x_val,y_val,\"validation\")\n","evaluate_model(x_test,y_test,\"Test\")\n","\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Cgov4QNkPpmP","executionInfo":{"status":"ok","timestamp":1772602173641,"user_tz":-330,"elapsed":13,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"585e8a90-830d-4bdc-8e96-b4e1f2bf1aea"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Training set performance\n","MAE: 1.3664781793837193\n","MSE: 3.029872390052725\n","RMSE: 1.740652863167359\n","R2: 0.6615918198260602\n","\n","validation set performance\n","MAE: 1.5832938447893297\n","MSE: 3.9606918513494835\n","RMSE: 1.990148700813455\n","R2: 0.4851604505229731\n","\n","Test set performance\n","MAE: 1.6740471268773023\n","MSE: 3.9189086085038736\n","RMSE: 1.9796233501613063\n","R2: 0.2099313038217735\n"]}]},{"cell_type":"code","source":["#STEP 5:k-FOLD CROSS VALIDATION(DIFFERENT k)\n","from sklearn.model_selection import cross_val_score\n","\n","def cross_validation_results(k):\n","  scores=cross_val_score(model,x,y,\n","scoring=\"neg_mean_squared_error\",cv=k)\n","  rmse_scores=np.sqrt(-scores)\n","\n","  print(f\"\\n{k}-Fold cross Validation Results\")\n","  print(\"RMSE per fold:\",rmse_scores)\n","  print(\"Average RMSE:\",rmse_scores.mean())\n","  print(\"Std Dev RMSE:\",rmse_scores.std())\n","\n","for k in [3,5,10]:\n","   cross_validation_results(k)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lUbSYdwTUbBf","executionInfo":{"status":"ok","timestamp":1772602759937,"user_tz":-330,"elapsed":101,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"513db2e0-b034-434f-87b4-5bdad4536be0"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","3-Fold cross Validation Results\n","RMSE per fold: [1.65238483 1.81800452 2.08071541]\n","Average RMSE: 1.8503682516917228\n","Std Dev RMSE: 0.17635632605392326\n","\n","5-Fold cross Validation Results\n","RMSE per fold: [1.75692743 1.69460487 1.6286888  1.81498321 2.37968162]\n","Average RMSE: 1.8549771848539023\n","Std Dev RMSE: 0.26961221269407826\n","\n","10-Fold cross Validation Results\n","RMSE per fold: [2.19271321 1.15457989 1.46792604 1.88297158 1.22329411 1.90463037\n"," 1.45252255 1.99262521 2.34252822 2.35106136]\n","Average RMSE: 1.7964852546595433\n","Std Dev RMSE: 0.42275434659127453\n"]}]}]}