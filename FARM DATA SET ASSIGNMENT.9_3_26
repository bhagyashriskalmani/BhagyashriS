{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNplLK005TQly58GQ6xqjgn"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GiGdldCpJJ1r","executionInfo":{"status":"ok","timestamp":1773030409068,"user_tz":-330,"elapsed":1699,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"57197720-0200-4d58-96f0-02ecdbb8427c"},"outputs":[{"output_type":"stream","name":"stdout","text":["      Rainfall  Temperature      Yield\n","0   699.632095    31.726483  34.777718\n","1  1160.571445    33.233552  40.464410\n","2   985.595153    23.406059  29.280510\n","3   878.926787    19.870883  24.119859\n","4   524.814912    21.874898  22.805385\n"]}],"source":["#step 1:Creating a farm dataset\n","import numpy as np\n","import pandas as pd\n","\n","np.random.seed(42)\n","#generate synthetic farming data\n","n=120\n","\n","rainfall=np.random.uniform(400,1200,n)  #mm\n","temperature=np.random.uniform(18,35,n)  #celsius\n","\n","#True relationship(unknown to model)\n","yield_tons=(0.005*rainfall+temperature+np.random.normal(0,2,n)) #noise\n","\n","data=pd.DataFrame({\n","    \"Rainfall\":rainfall,\n","    \"Temperature\":temperature,\n","    \"Yield\":yield_tons\n","})\n","\n","print(data.head())"]},{"cell_type":"code","source":["#Step 2:split into Train,Validation,Test, 80% Train,20% Validation,10% Test\n","from sklearn.model_selection import train_test_split\n","x=data[[\"Rainfall\",\"Temperature\"]]\n","y=data[\"Yield\"]\n","\n","#First split:Train(80%) and Temp (20%)\n","x_train,x_temp,y_train,y_temp=train_test_split(x,y,test_size=0.30,random_state=1)\n","\n","#second split:validation(10%) and Test(10%)\n","x_val,x_test,y_val,y_test=train_test_split(x_temp,y_temp,test_size=0.50,random_state=1)\n","\n","\n","print(\"Training set:\",x_train.shape)\n","print(\"Validation:\",x_val.shape)\n","print(\"Test set:\",x_test.shape)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IAu7olU-LVMx","executionInfo":{"status":"ok","timestamp":1773030553021,"user_tz":-330,"elapsed":1072,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"b8ef7356-d2fe-4ffb-985f-df2bc096dd3d"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Training set: (84, 2)\n","Validation: (18, 2)\n","Test set: (18, 2)\n"]}]},{"cell_type":"code","source":["#STEP 3:Train Regression model\n","from sklearn.linear_model import LinearRegression\n","\n","model=LinearRegression()\n","model.fit(x_train,y_train)\n","\n","#STEP 4:EVALUATE USING REGRESSION METRICS\n","from sklearn.metrics import mean_absolute_error,mean_squared_error,r2_score\n","\n","def evaluate_model(x,y,name):\n","  y_pred=model.predict(x)\n","  mae=mean_absolute_error(y,y_pred)\n","  mse=mean_squared_error(y,y_pred)\n","  rmse=np.sqrt(mse)\n","  r2=r2_score(y,y_pred)\n","\n","  print(f\"\\n{name} set performance\")\n","  print(\"MAE:\",mae)\n","  print(\"MSE:\",mse)\n","  print(\"RMSE:\",rmse)\n","  print(\"R2:\",r2)\n","\n","evaluate_model(x_train,y_train,\"Training\")\n","evaluate_model(x_val,y_val,\"validation\")\n","evaluate_model(x_test,y_test,\"Test\")\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Cgov4QNkPpmP","executionInfo":{"status":"ok","timestamp":1773030592830,"user_tz":-330,"elapsed":233,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"aef0dee2-9c11-4856-c987-69ea661cb348"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Training set performance\n","MAE: 1.7542460050912758\n","MSE: 4.991988879698113\n","RMSE: 2.2342759184348995\n","R2: 0.8033657634538995\n","\n","validation set performance\n","MAE: 1.3774634833034147\n","MSE: 2.736607202215806\n","RMSE: 1.6542693862294031\n","R2: 0.8763239031953358\n","\n","Test set performance\n","MAE: 1.0057973865125323\n","MSE: 1.3119371206434547\n","RMSE: 1.1453982367034858\n","R2: 0.946911584661805\n"]}]},{"cell_type":"code","source":["#STEP 5:k-FOLD CROSS VALIDATION(DIFFERENT k)\n","from sklearn.model_selection import cross_val_score\n","\n","def cross_validation_results(k):\n","  scores=cross_val_score(model,x,y,\n","scoring=\"neg_mean_squared_error\",cv=k)\n","  rmse_scores=np.sqrt(-scores)\n","\n","  print(f\"\\n{k}-Fold cross Validation Results\")\n","  print(\"RMSE per fold:\",rmse_scores)\n","  print(\"Average RMSE:\",rmse_scores.mean())\n","  print(\"Std Dev RMSE:\",rmse_scores.std())\n","\n","for k in [3,5,10]:\n","   cross_validation_results(k)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lUbSYdwTUbBf","executionInfo":{"status":"ok","timestamp":1773030611915,"user_tz":-330,"elapsed":18,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"1802b2b9-60bb-4b55-9fff-16323902dabf"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","3-Fold cross Validation Results\n","RMSE per fold: [2.10558166 2.18345363 1.81359058]\n","Average RMSE: 2.034208627026811\n","Std Dev RMSE: 0.15920689154057271\n","\n","5-Fold cross Validation Results\n","RMSE per fold: [1.6982739  2.37460184 2.14876772 2.16341745 1.91412713]\n","Average RMSE: 2.0598376092038433\n","Std Dev RMSE: 0.23223855127062837\n","\n","10-Fold cross Validation Results\n","RMSE per fold: [1.55241472 1.78487028 2.46698083 2.32750647 1.97617579 2.30983259\n"," 2.65508553 1.43594732 2.32502942 1.40229646]\n","Average RMSE: 2.0236139411895664\n","Std Dev RMSE: 0.43279541753549716\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import numpy as np\n","data=np.random.normal(170,10,250)\n","plt.hist(data,bins=20)\n","plt.xlabel(\"TEMPERATURE\")\n","plt.ylabel(\"YIELD\")\n","plt.title(\"HISTOGRAM EXAMPLE\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"I2pKs5AkJsPe","executionInfo":{"status":"ok","timestamp":1773031363898,"user_tz":-330,"elapsed":341,"user":{"displayName":"Bhagyashri S Kalmani","userId":"03323828181537196808"}},"outputId":"4cff0b5a-1483-4e3b-99b4-979914b54be5"},"execution_count":5,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}